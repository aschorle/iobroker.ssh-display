{
	"i18n": true,
	"type": "panel",
	"items": {
		"sshKeyHelp": {
			"type": "staticText",
			"label": "SSH-Schlüssel einrichten",
			"text": "1. Schlüssel erzeugen:\nsudo -u iobroker -H mkdir -p /home/iobroker/.ssh\nsudo -u iobroker -H ssh-keygen -t ed25519 -f /home/iobroker/.ssh/id_ed25519 -N \"\"\n\n2. Öffentlichen Schlüssel anzeigen:\ncat /home/iobroker/.ssh/id_ed25519.pub\n\n3. Auf Zielsystem in ~/.ssh/authorized_keys einfügen.\n\n4. Rechte setzen:\nchmod 700 ~/.ssh\nchmod 600 ~/.ssh/authorized_keys\n\n5. Verbindung testen:\nsudo -u iobroker ssh -i /home/iobroker/.ssh/id_ed25519 BENUTZER@IP hostname\n\nprivateKeyPath im Adapter:\n/home/iobroker/.ssh/id_ed25519",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"hosts": {
			"type": "table",
			"label": "Hosts",
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12,
			"items": [
				{
					"attr": "id",
					"type": "text",
					"title": "ID",
					"width": "120px"
				},
				{
					"attr": "name",
					"type": "text",
					"title": "Name",
					"width": "160px"
				},
				{
					"attr": "host",
					"type": "text",
					"title": "Host",
					"width": "180px"
				},
				{
					"attr": "port",
					"type": "number",
					"title": "Port",
					"default": 22,
					"width": "100px"
				},
				{
					"attr": "username",
					"type": "text",
					"title": "Username",
					"width": "160px"
				},
				{
					"attr": "privateKeyPath",
					"type": "text",
					"title": "Private key path",
					"width": "240px"
				},
				{
					"attr": "displayMethod",
					"type": "select",
					"title": "Display method",
					"default": "xrandr-hdmi-1",
					"width": "180px",
					"options": [
						{
							"label": "xrandr HDMI-1",
							"value": "xrandr-hdmi-1"
						},
						{
							"label": "xrandr HDMI-A-1",
							"value": "xrandr-hdmi-a-1"
						},
						{
							"label": "vcgencmd",
							"value": "vcgencmd"
						},
						{
							"label": "Custom",
							"value": "custom"
						}
					]
				},
				{
					"attr": "displayOnCommand",
					"type": "text",
					"title": "Display on command",
					"hidden": "data.displayMethod !== 'custom'",
					"width": "240px"
				},
				{
					"attr": "displayOffCommand",
					"type": "text",
					"title": "Display off command",
					"hidden": "data.displayMethod !== 'custom'",
					"width": "240px"
				}
			]
		}
	}
}
