{
	"i18n": true,
	"type": "panel",
	"items": {
		"hostsHelp": {
			"type": "staticText",
			"text": "Nach dem Speichern startet der Adapter neu und pr\u00fcft automatisch die SSH-Verbindung. Der Status erscheint unter Objekte -> ssh-display.0 -> hosts.",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"hosts": {
			"type": "table",
			"label": "Hosts",
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12,
			"items": [
				{
					"attr": "id",
					"type": "text",
					"title": "ID",
					"width": "120px"
				},
				{
					"attr": "name",
					"type": "text",
					"title": "Name",
					"width": "180px"
				},
				{
					"attr": "host",
					"type": "text",
					"title": "Server / IP",
					"width": "180px"
				},
				{
					"attr": "username",
					"type": "text",
					"title": "Benutzer",
					"width": "140px"
				},
				{
					"type": "panel",
					"label": "Host konfigurieren",
					"items": {
						"privateKeyPath": {
							"type": "text",
							"label": "SSH-Schl\u00fcsselpfad (auf dem ioBroker-Server)",
							"default": "/home/iobroker/.ssh/id_ed25519",
							"newLine": true,
							"sm": 12,
							"md": 12,
							"lg": 12,
							"xl": 12
						},
						"displayBackend": {
							"type": "select",
							"label": "Display-Backend",
							"default": "x11",
							"newLine": true,
							"sm": 12,
							"md": 6,
							"lg": 4,
							"xl": 4,
							"options": [
								{
									"label": "Linux X11",
									"value": "x11"
								},
								{
									"label": "Raspberry Pi - vcgencmd",
									"value": "vcgencmd"
								},
								{
									"label": "Benutzerdefiniert",
									"value": "custom"
								}
							]
						},
						"displayOutput": {
							"type": "selectSendTo",
							"label": "Display-Ausgang",
							"command": "detectDisplays",
							"jsonData": "{\"host\":{\"id\":\"${data.id}\",\"host\":\"${data.host}\",\"port\":\"${data.port}\",\"username\":\"${data.username}\",\"privateKeyPath\":\"${data.privateKeyPath}\",\"displayBackend\":\"${data.displayBackend}\",\"displayOutput\":\"${data.displayOutput}\"}}",
							"default": "HDMI-1",
							"manual": true,
							"alsoDependsOn": [
								"id",
								"displayBackend"
							],
							"hidden": "data.displayBackend !== 'x11'",
							"sm": 12,
							"md": 6,
							"lg": 4,
							"xl": 4
						},
						"testConnection": {
							"type": "sendTo",
							"command": "testConnection",
							"jsonData": "{\"host\":{\"id\":\"${data.id}\",\"host\":\"${data.host}\",\"port\":\"${data.port}\",\"username\":\"${data.username}\",\"privateKeyPath\":\"${data.privateKeyPath}\",\"displayBackend\":\"${data.displayBackend}\",\"displayOutput\":\"${data.displayOutput}\"}}",
							"label": "Verbindung testen",
							"variant": "outlined",
							"showProcess": true,
							"newLine": true,
							"sm": 12,
							"md": 4,
							"lg": 3,
							"xl": 3
						},
						"connectionStatusLabel": {
							"type": "staticText",
							"text": "Status:",
							"sm": 12,
							"md": 4,
							"lg": 3,
							"xl": 3
						},
						"connectionHostnameLabel": {
							"type": "staticText",
							"text": "Hostname:",
							"sm": 12,
							"md": 4,
							"lg": 3,
							"xl": 3
						},
						"detectDisplays": {
							"type": "sendTo",
							"command": "detectDisplays",
							"jsonData": "{\"host\":{\"id\":\"${data.id}\",\"host\":\"${data.host}\",\"port\":\"${data.port}\",\"username\":\"${data.username}\",\"privateKeyPath\":\"${data.privateKeyPath}\",\"displayBackend\":\"${data.displayBackend}\",\"displayOutput\":\"${data.displayOutput}\"}}",
							"label": "Displays erkennen",
							"variant": "outlined",
							"showProcess": true,
							"hidden": "data.displayBackend !== 'x11'",
							"newLine": true,
							"sm": 12,
							"md": 4,
							"lg": 3,
							"xl": 3
						},
						"detectedDisplaysLabel": {
							"type": "staticText",
							"text": "Gefundene Displays",
							"hidden": "data.displayBackend !== 'x11'",
							"sm": 12,
							"md": 8,
							"lg": 6,
							"xl": 6
						}
					}
				}
			]
		},
		"sshKeyStatus": {
			"type": "textSendTo",
			"label": "Status",
			"command": "getSshKeyStatus",
			"newLine": true,
			"sm": 12,
			"md": 6,
			"lg": 6,
			"xl": 6
		},
		"firstHostTitle": {
			"type": "header",
			"size": 4,
			"text": "Erster Host",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"generateSshKey": {
			"type": "sendTo",
			"command": "generateSshKey",
			"label": "1. SSH-Schl\u00fcssel erzeugen",
			"variant": "outlined",
			"showProcess": true,
			"result": {
				"SSH-Schl\u00fcssel wurde erzeugt": "SSH-Schl\u00fcssel wurde erzeugt",
				"SSH-Schl\u00fcssel ist bereits vorhanden": "SSH-Schl\u00fcssel ist bereits vorhanden"
			},
			"newLine": true,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"showPublicKey": {
			"type": "sendTo",
			"command": "getPublicKey",
			"label": "2. Public Key anzeigen",
			"variant": "outlined",
			"showProcess": true,
			"newLine": true,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"publicKey": {
			"type": "textSendTo",
			"label": "Public Key",
			"command": "getPublicKey",
			"copyToClipboard": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"firstHostAuthorizedKeys": {
			"type": "text",
			"label": "3. Auf dem Zielgerät: Public Key einfügen",
			"default": "nano ~/.ssh/authorized_keys",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"firstHostTest": {
			"type": "staticText",
			"text": "4. Verbindung im jeweiligen Host testen",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"additionalHostsTitle": {
			"type": "header",
			"size": 4,
			"text": "Weitere Hosts",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"additionalHostsAuthorizedKeys": {
			"type": "text",
			"label": "Denselben Public Key einfügen",
			"default": "nano ~/.ssh/authorized_keys",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"additionalHostsTest": {
			"type": "staticText",
			"text": "Danach Verbindung im jeweiligen Host testen",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		}
	}
}
