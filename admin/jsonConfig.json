{
	"i18n": true,
	"type": "panel",
	"items": {
		"hostsHelp": {
			"type": "staticText",
			"text": "Nach dem Speichern startet der Adapter neu und pr\u00fcft automatisch die SSH-Verbindung. Der Status erscheint unter Objekte -> ssh-display.0 -> hosts.",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"hosts": {
			"type": "table",
			"label": "Hosts",
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12,
			"items": [
				{
					"attr": "id",
					"type": "text",
					"title": "ID (nach dem ersten Speichern nicht mehr ändern)",
					"width": "120px"
				},
				{
					"attr": "name",
					"type": "text",
					"title": "Name",
					"width": "180px"
				},
				{
					"attr": "host",
					"type": "text",
					"title": "Server / IP",
					"width": "180px"
				},
				{
					"attr": "username",
					"type": "text",
					"title": "Benutzer",
					"width": "140px"
				},
				{
					"attr": "privateKeyPath",
					"type": "text",
					"default": "/home/iobroker/.ssh/id_ed25519",
					"hidden": true,
					"width": "0px"
				},
				{
					"attr": "displayOutput",
					"type": "text",
					"default": "HDMI-1",
					"hidden": true,
					"width": "0px"
				},
				{
					"type": "panel",
					"label": "Host konfigurieren",
					"items": {
						"privateKeyPath": {
							"type": "text",
							"label": "SSH-Schl\u00fcsselpfad (auf dem ioBroker-Server)",
							"default": "/home/iobroker/.ssh/id_ed25519",
							"newLine": true,
							"sm": 12,
							"md": 12,
							"lg": 12,
							"xl": 12
						},
						"displayBackend": {
							"type": "select",
							"label": "Display-Backend",
							"default": "x11",
							"newLine": true,
							"sm": 12,
							"md": 12,
							"lg": 12,
							"xl": 12,
							"options": [
								{
									"label": "Automatisch (vcgencmd, ddcutil, X11, benutzerdefiniert)",
									"value": "auto"
								},
								{
									"label": "Linux X11",
									"value": "x11"
								},
								{
									"label": "Raspberry Pi - vcgencmd",
									"value": "vcgencmd"
								},
								{
									"label": "DDC/CI - ddcutil",
									"value": "ddcutil"
								},
								{
									"label": "Benutzerdefiniert",
									"value": "custom"
								}
							]
						},
						"automaticBackendHint": {
							"type": "staticText",
							"text": "Automatische Auswahl: ddcutil wird nur gewählt, wenn es auf dem entfernten Linux-Host bereits installiert ist und ein kompatibles Display mit D6 erkannt wird. Der Adapter installiert keine Pakete und führt niemals sudo aus. Der SSH-Benutzer muss ddcutil ohne sudo und ohne interaktive Passwortabfrage ausführen können. Empfohlen ist root mit SSH-Schlüssel und deaktivierter Passwortanmeldung; alternativ ist ein Benutzer mit Zugriff auf /dev/i2c-* möglich.",
							"hidden": "data.displayBackend !== 'auto'",
							"newLine": true,
							"sm": 12,
							"md": 12,
							"lg": 12,
							"xl": 12
						},
						"ddcutilBackendHint": {
							"type": "staticText",
							"text": "Voraussetzung: ddcutil muss auf dem Zielhost installiert sein. Der konfigurierte SSH-Benutzer muss ddcutil ohne sudo und ohne Passwortabfrage ausführen können und Zugriff auf /dev/i2c-* haben. Empfohlen: root per SSH-Schlüssel bei deaktivierter Passwortanmeldung. Der Adapter installiert nichts und führt niemals sudo aus.",
							"hidden": "data.displayBackend !== 'ddcutil'",
							"newLine": true,
							"sm": 12,
							"md": 12,
							"lg": 12,
							"xl": 12
						},
						"displayOutput": {
							"type": "text",
							"label": "Display-Ausgang",
							"default": "HDMI-1",
							"hidden": "data.displayBackend !== 'x11'",
							"newLine": true,
							"sm": 12,
							"md": 12,
							"lg": 12,
							"xl": 12
						},
						"displayOutputHint": {
							"type": "staticText",
							"text": "Standard: HDMI-1. Mit 'Displays erkennen' kann der tatsächliche Display-Ausgang ermittelt werden.",
							"hidden": "data.displayBackend !== 'x11'",
							"newLine": true,
							"sm": 12,
							"md": 12,
							"lg": 12,
							"xl": 12
						},
						"testConnection": {
							"type": "sendTo",
							"command": "testConnection",
							"jsonData": "{\"host\":{\"id\":\"${data.id}\",\"host\":\"${data.host}\",\"port\":\"${data.port}\",\"username\":\"${data.username}\",\"privateKeyPath\":\"${data.privateKeyPath}\",\"displayBackend\":\"${data.displayBackend}\",\"displayOutput\":\"${data.displayOutput}\"}}",
							"label": "Verbindung testen",
							"variant": "outlined",
							"showProcess": true,
							"newLine": true,
							"sm": 12,
							"md": 6,
							"lg": 4,
							"xl": 3,
							"controlStyle": {
								"maxWidth": "260px"
							}
						},
						"detectDisplays": {
							"type": "sendTo",
							"command": "detectDisplays",
							"jsonData": "{\"host\":{\"id\":\"${data.id}\",\"host\":\"${data.host}\",\"port\":\"${data.port}\",\"username\":\"${data.username}\",\"privateKeyPath\":\"${data.privateKeyPath}\",\"displayBackend\":\"${data.displayBackend}\",\"displayOutput\":\"${data.displayOutput}\"}}",
							"label": "Displays erkennen",
							"variant": "outlined",
							"showProcess": true,
							"hidden": "data.displayBackend !== 'x11'",
							"newLine": true,
							"sm": 12,
							"md": 6,
							"lg": 4,
							"xl": 3,
							"controlStyle": {
								"maxWidth": "260px"
							}
						}
					}
				}
			]
		},
		"_sshKeyStatus": {
			"type": "text",
			"label": "Status",
			"readOnly": true,
			"doNotSave": true,
			"defaultSendTo": "getSshKeyStatus",
			"newLine": true,
			"sm": 12,
			"md": 6,
			"lg": 6,
			"xl": 6
		},
		"reuseSshKeyHint": {
			"type": "staticText",
			"text": "Wenn bereits ein SSH-Schlüssel vorhanden ist, diesen weiterverwenden.",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"generateSshKey": {
			"type": "sendTo",
			"command": "generateSshKey",
			"label": "1. SSH-Schl\u00fcssel erzeugen",
			"variant": "outlined",
			"showProcess": true,
			"useNative": true,
			"result": {
				"SSH-Schl\u00fcssel wurde erzeugt": "SSH-Schl\u00fcssel wurde erzeugt",
				"SSH-Schl\u00fcssel ist bereits vorhanden": "SSH-Schl\u00fcssel ist bereits vorhanden"
			},
			"newLine": true,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"sshKeyActionsHint": {
			"type": "staticText",
			"text": "SSH-Schl\u00fcsselaktionen werden sofort auf dem ioBroker-Server ausgef\u00fchrt. Ein Speichern der Instanzkonfiguration ist daf\u00fcr nicht erforderlich.",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12,
			"style": {
				"fontWeight": 500,
				"marginTop": 8,
				"marginBottom": 8
			}
		},
		"showPublicKey": {
			"type": "sendTo",
			"command": "getPublicKey",
			"label": "2. Public Key anzeigen",
			"variant": "outlined",
			"showProcess": true,
			"useNative": true,
			"newLine": true,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"_publicKey": {
			"type": "text",
			"label": "Public Key",
			"readOnly": true,
			"doNotSave": true,
			"copyToClipboard": true,
			"minRows": 2,
			"maxRows": 4,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"firstHostAuthorizedKeys": {
			"type": "text",
			"label": "3. Auf dem Zielgerät: Public Key einfügen",
			"default": "nano ~/.ssh/authorized_keys",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"firstHostAuthorizedKeysNote": {
			"type": "staticText",
			"text": "Public Key als neue Zeile einfügen und speichern.",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"firstHostTest": {
			"type": "staticText",
			"text": "4. Host anlegen",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"instructionTestConnection": {
			"type": "staticText",
			"text": "5. Verbindung testen",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"instructionDetectDisplays": {
			"type": "staticText",
			"text": "6. Displays erkennen",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"instructionSelectDisplay": {
			"type": "staticText",
			"text": "7. Display-Ausgang auswählen",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		}
	}
}
