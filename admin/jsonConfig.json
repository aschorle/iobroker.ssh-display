{
	"i18n": true,
	"type": "panel",
	"items": {
		"hostsHelp": {
			"type": "staticText",
			"text": "Nach dem Speichern startet der Adapter neu und pr\u00fcft automatisch die SSH-Verbindung. Der Status erscheint unter Objekte -> ssh-display.0 -> hosts.",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"hosts": {
			"type": "table",
			"label": "Hosts",
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12,
			"items": [
				{
					"attr": "id",
					"type": "text",
					"title": "ID",
					"width": "120px"
				},
				{
					"attr": "name",
					"type": "text",
					"title": "Name",
					"width": "180px"
				},
				{
					"attr": "host",
					"type": "text",
					"title": "Server / IP",
					"width": "180px"
				},
				{
					"attr": "username",
					"type": "text",
					"title": "Benutzer",
					"width": "140px"
				},
				{
					"type": "panel",
					"label": "Host konfigurieren",
					"items": {
						"privateKeyPath": {
							"type": "text",
							"label": "SSH-Schl\u00fcssel",
							"newLine": true,
							"sm": 12,
							"md": 12,
							"lg": 12,
							"xl": 12
						},
						"displayBackend": {
							"type": "select",
							"label": "Display-Backend",
							"default": "x11",
							"newLine": true,
							"sm": 12,
							"md": 6,
							"lg": 4,
							"xl": 4,
							"options": [
								{
									"label": "Linux X11",
									"value": "x11"
								},
								{
									"label": "Raspberry Pi - vcgencmd",
									"value": "vcgencmd"
								},
								{
									"label": "Benutzerdefiniert",
									"value": "custom"
								}
							]
						},
						"displayOutput": {
							"type": "selectSendTo",
							"label": "Display-Ausgang",
							"command": "detectDisplays",
							"jsonData": "{\"hostId\":\"${data.id}\"}",
							"default": "HDMI-1",
							"manual": true,
							"alsoDependsOn": [
								"id",
								"displayBackend"
							],
							"hidden": "data.displayBackend !== 'x11'",
							"sm": 12,
							"md": 6,
							"lg": 4,
							"xl": 4
						},
						"testConnection": {
							"type": "sendTo",
							"command": "testConnection",
							"jsonData": "{\"hostId\":\"${data.id}\"}",
							"label": "Verbindung testen",
							"variant": "outlined",
							"showProcess": true,
							"newLine": true,
							"sm": 12,
							"md": 4,
							"lg": 3,
							"xl": 3
						},
						"connectionStatusLabel": {
							"type": "staticText",
							"text": "Status:",
							"sm": 12,
							"md": 4,
							"lg": 3,
							"xl": 3
						},
						"connectionHostnameLabel": {
							"type": "staticText",
							"text": "Hostname:",
							"sm": 12,
							"md": 4,
							"lg": 3,
							"xl": 3
						},
						"detectDisplays": {
							"type": "sendTo",
							"command": "detectDisplays",
							"jsonData": "{\"hostId\":\"${data.id}\"}",
							"label": "Displays erkennen",
							"variant": "outlined",
							"showProcess": true,
							"hidden": "data.displayBackend !== 'x11'",
							"newLine": true,
							"sm": 12,
							"md": 4,
							"lg": 3,
							"xl": 3
						},
						"detectedDisplaysLabel": {
							"type": "staticText",
							"text": "Gefundene Displays",
							"hidden": "data.displayBackend !== 'x11'",
							"sm": 12,
							"md": 8,
							"lg": 6,
							"xl": 6
						}
					}
				}
			]
		},
		"sshKeyHelpTitle": {
			"type": "header",
			"size": 3,
			"text": "SSH-Schl\u00fcssel einrichten",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep1": {
			"type": "header",
			"size": 4,
			"text": "Schritt 1",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep1Mkdir": {
			"type": "text",
			"label": "Befehl",
			"text": "sudo -u iobroker -H mkdir -p /home/iobroker/.ssh",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep1Keygen": {
			"type": "text",
			"label": "Befehl",
			"text": "sudo -u iobroker -H ssh-keygen -t ed25519 -f /home/iobroker/.ssh/id_ed25519 -N \"\"",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep2": {
			"type": "header",
			"size": 4,
			"text": "Schritt 2",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep2Cat": {
			"type": "text",
			"label": "Befehl",
			"text": "cat /home/iobroker/.ssh/id_ed25519.pub",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep3": {
			"type": "header",
			"size": 4,
			"text": "Schritt 3",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep3Mkdir": {
			"type": "text",
			"label": "Befehl",
			"text": "mkdir -p ~/.ssh",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep3Nano": {
			"type": "text",
			"label": "Befehl",
			"text": "nano ~/.ssh/authorized_keys",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep3Note": {
			"type": "staticText",
			"text": "Schl\u00fcssel als neue Zeile einf\u00fcgen.",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep4": {
			"type": "header",
			"size": 4,
			"text": "Schritt 4",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep4Dir": {
			"type": "text",
			"label": "Befehl",
			"text": "chmod 700 ~/.ssh",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep4File": {
			"type": "text",
			"label": "Befehl",
			"text": "chmod 600 ~/.ssh/authorized_keys",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep5": {
			"type": "header",
			"size": 4,
			"text": "Schritt 5",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep5Test": {
			"type": "text",
			"label": "Befehl",
			"text": "sudo -u iobroker ssh -i /home/iobroker/.ssh/id_ed25519 BENUTZER@IP hostname",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep6": {
			"type": "header",
			"size": 4,
			"text": "Schritt 6",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep6Label": {
			"type": "staticText",
			"text": "privateKeyPath",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep6Path": {
			"type": "text",
			"label": "Pfad",
			"text": "/home/iobroker/.ssh/id_ed25519",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		}
	}
}
