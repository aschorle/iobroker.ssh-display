{
	"i18n": true,
	"type": "panel",
	"items": {
		"hostsHelp": {
			"type": "staticText",
			"text": "Nach dem Speichern startet der Adapter neu und pr\u00fcft automatisch die SSH-Verbindung. Der Status erscheint unter Objekte -> ssh-display.0 -> hosts.",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"hosts": {
			"type": "table",
			"label": "Hosts",
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12,
			"items": [
				{
					"attr": "id",
					"type": "text",
					"title": "ID",
					"width": "120px"
				},
				{
					"attr": "name",
					"type": "text",
					"title": "Name",
					"width": "180px"
				},
				{
					"attr": "host",
					"type": "text",
					"title": "Server / IP",
					"width": "180px"
				},
				{
					"attr": "username",
					"type": "text",
					"title": "Benutzer",
					"width": "140px"
				},
				{
					"type": "panel",
					"label": "Host konfigurieren",
					"items": {
						"privateKeyPath": {
							"type": "text",
							"label": "SSH-Schl\u00fcssel",
							"newLine": true,
							"sm": 12,
							"md": 12,
							"lg": 12,
							"xl": 12
						},
						"displayBackend": {
							"type": "select",
							"label": "Display-Backend",
							"default": "x11",
							"newLine": true,
							"sm": 12,
							"md": 6,
							"lg": 4,
							"xl": 4,
							"options": [
								{
									"label": "Linux X11",
									"value": "x11"
								},
								{
									"label": "Raspberry Pi - vcgencmd",
									"value": "vcgencmd"
								},
								{
									"label": "Benutzerdefiniert",
									"value": "custom"
								}
							]
						},
						"displayOutput": {
							"type": "selectSendTo",
							"label": "Display-Ausgang",
							"command": "detectDisplays",
							"jsonData": "{\"host\":{\"id\":\"${data.id}\",\"host\":\"${data.host}\",\"port\":\"${data.port}\",\"username\":\"${data.username}\",\"privateKeyPath\":\"${data.privateKeyPath}\",\"displayBackend\":\"${data.displayBackend}\",\"displayOutput\":\"${data.displayOutput}\"}}",
							"default": "HDMI-1",
							"manual": true,
							"alsoDependsOn": [
								"id",
								"displayBackend"
							],
							"hidden": "data.displayBackend !== 'x11'",
							"sm": 12,
							"md": 6,
							"lg": 4,
							"xl": 4
						},
						"testConnection": {
							"type": "sendTo",
							"command": "testConnection",
							"jsonData": "{\"host\":{\"id\":\"${data.id}\",\"host\":\"${data.host}\",\"port\":\"${data.port}\",\"username\":\"${data.username}\",\"privateKeyPath\":\"${data.privateKeyPath}\",\"displayBackend\":\"${data.displayBackend}\",\"displayOutput\":\"${data.displayOutput}\"}}",
							"label": "Verbindung testen",
							"variant": "outlined",
							"showProcess": true,
							"newLine": true,
							"sm": 12,
							"md": 4,
							"lg": 3,
							"xl": 3
						},
						"connectionStatusLabel": {
							"type": "staticText",
							"text": "Status:",
							"sm": 12,
							"md": 4,
							"lg": 3,
							"xl": 3
						},
						"connectionHostnameLabel": {
							"type": "staticText",
							"text": "Hostname:",
							"sm": 12,
							"md": 4,
							"lg": 3,
							"xl": 3
						},
						"detectDisplays": {
							"type": "sendTo",
							"command": "detectDisplays",
							"jsonData": "{\"host\":{\"id\":\"${data.id}\",\"host\":\"${data.host}\",\"port\":\"${data.port}\",\"username\":\"${data.username}\",\"privateKeyPath\":\"${data.privateKeyPath}\",\"displayBackend\":\"${data.displayBackend}\",\"displayOutput\":\"${data.displayOutput}\"}}",
							"label": "Displays erkennen",
							"variant": "outlined",
							"showProcess": true,
							"hidden": "data.displayBackend !== 'x11'",
							"newLine": true,
							"sm": 12,
							"md": 4,
							"lg": 3,
							"xl": 3
						},
						"detectedDisplaysLabel": {
							"type": "staticText",
							"text": "Gefundene Displays",
							"hidden": "data.displayBackend !== 'x11'",
							"sm": 12,
							"md": 8,
							"lg": 6,
							"xl": 6
						}
					}
				}
			]
		},
		"sshKeyStep1": {
			"type": "text",
			"label": "Schritt 1 \u2013 SSH-Verzeichnis",
			"default": "sudo -u iobroker -H mkdir -p /home/iobroker/.ssh",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep2": {
			"type": "text",
			"label": "Schritt 2 \u2013 Schl\u00fcssel erzeugen",
			"default": "sudo -u iobroker -H ssh-keygen -t ed25519 -f /home/iobroker/.ssh/id_ed25519 -N \"\"",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep3": {
			"type": "text",
			"label": "Schritt 3 \u2013 Public Key anzeigen",
			"default": "cat /home/iobroker/.ssh/id_ed25519.pub",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep4": {
			"type": "staticText",
			"text": "Schritt 4 \u2013 Public Key auf dem Zielsystem in ~/.ssh/authorized_keys einf\u00fcgen",
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep5": {
			"type": "text",
			"label": "Schritt 5 \u2013 Verbindung testen",
			"default": "sudo -u iobroker ssh -i /home/iobroker/.ssh/id_ed25519 <BENUTZER>@<HOST> hostname",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"sshKeyStep6": {
			"type": "text",
			"label": "Schritt 6 \u2013 Adapter: privateKeyPath",
			"default": "/home/iobroker/.ssh/id_ed25519",
			"readOnly": true,
			"copyToClipboard": true,
			"doNotSave": true,
			"newLine": true,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		}
	}
}
